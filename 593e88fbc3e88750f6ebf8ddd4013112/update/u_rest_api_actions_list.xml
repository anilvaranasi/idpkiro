    var engine = new x_146833_idpkiro.IDPSelfServiceEngine();
    var actions = engine.getAvailableActions(userId);

    response.setStatus(200);
    response.setBody({
        success: true,
        count: actions.length,
        actions: actions
    });
})(request, response);]]></operation_script>
