        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
    var formId = request.pathParams.formId;
    
    if (!formId) {
        response.setStatus(400);
        response.setError('formId is required');
        return;
    }

    var engine = new x_146833_idpkiro.IDPSelfServiceEngine();
    var form = engine.getFormDefinition(formId);

    if (!form.sys_id) {
        response.setStatus(404);
        response.setError('Form not found');
        return;
    }

    response.setStatus(200);
    response.setBody({
        success: true,
        form: form
    });
})(request, response);]]></operation_script>
