        <default_operation_uri>/api/x_146833_idpkiro/scorecard/calculate</default_operation_uri>
        <operation_name>calculate_scorecard</operation_name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
    var body = request.body.data;
    
    if (!body.scorecardId || !body.entityId) {
        response.setStatus(400);
        response.setError('scorecardId and entityId are required');
        return;
    }

    var engine = new x_146833_idpkiro.IDPScorecardEngine();
    var result = engine.calculateScore(body.scorecardId, body.entityId);

    response.setStatus(200);
    response.setBody({
        success: true,
        result: result
    });
})(request, response);]]></operation_script>
        <produces>application/json</produces>
