        <condition/>
        <description>Invalidate IDP navigation cache when a user's role assignment changes. Ensures navigation tree reflects role changes immediately on next load.</description>
        <execute_function>false</execute_function>
        <filter_condition/>
        <is_rest>false</is_rest>
        <message/>
        <name>IDP - Invalidate Nav Cache on Role Chang</name>
        <order>100</order>
        <priority>100</priority>
        <rest_method/>
        <rest_method_text/>
        <rest_service/>
        <rest_service_text/>
        <rest_variables/>
        <role_conditions/>
        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {
    try {
        var userId = current.getValue('user');
        if (!userId) {
            return;
        }
        var navEngine = new x_146833_idpkiro.IDPNavigationEngine();
        navEngine.invalidateCache(userId);

        var catalogEngine = new x_146833_idpkiro.IDPCatalogEngine();
        catalogEngine.invalidateCache(userId);

    } catch (e) {
        gs.logError('IDP cache invalidation BR error: ' + e.message, 'IDP-CacheInvalidation');
    }
})(current, previous);
]]></script>
